<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Scarica un archivio completo dei tuoi dati personali, post pubblicati e preferenze dell'algoritmo strutturati in formato standard."
        android:textColor="#666666"
        android:textSize="13sp"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnExportJson"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Esporta in JSON"
            android:textColor="#FFFFFF"
            android:backgroundTint="#328CC1"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btnExportHtml"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Esporta in HTML"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0B3C5D"
            android:layout_marginStart="6dp"/>
    </LinearLayout>
</LinearLayout>