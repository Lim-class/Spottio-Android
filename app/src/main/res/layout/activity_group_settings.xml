<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/btnLeaveGroup">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp"
                android:background="#FFFFFF"
                android:elevation="4dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/ivGroupIcon"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@android:drawable/sym_def_app_icon"
                    app:civ_border_width="2dp"
                    app:civ_border_color="#CCCCCC" />

                <TextView
                    android:id="@+id/tvEditIconHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tocca l'immagine per modificarla"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:id="@+id/tvGroupName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nome Gruppo"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#212121" />

                    <ImageButton
                        android:id="@+id/btnEditGroupName"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="#1DB954"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/tvGroupDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nessuna descrizione"
                        android:textSize="14sp"
                        android:textColor="#666666" />

                    <ImageButton
                        android:id="@+id/btnEditGroupDesc"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_marginStart="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="#888888"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PARTECIPANTI"
                android:textStyle="bold"
                android:textColor="#888888"
                android:paddingStart="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp" />

            <com.example.spottio.NonScrollListView
                android:id="@+id/lvGroupMembers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="#E0E0E0"
                android:dividerHeight="1dp"
                android:background="#FFFFFF"/>

            <Button
                android:id="@+id/btnAddMember"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:backgroundTint="#1DB954"
                android:textColor="#FFFFFF"
                android:text="Aggiungi Partecipante"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="80dp" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnLeaveGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF"
        android:text="Abbandona Gruppo"
        android:textStyle="bold" />

</RelativeLayout>