<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Motivo: Spam"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#D32F2F"/>

        <TextView
            android:id="@+id/tvReporter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Segnalato da: User1"
            android:textColor="#757575"/>

        <TextView
            android:id="@+id/tvReportedUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Autore post: User2"
            android:textColor="#757575"/>

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Descrizione: ..."
            android:textColor="#333333"/>

        <TextView
            android:id="@+id/tvPostText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Testo Post: ..."
            android:background="#F0F0F0"
            android:padding="8dp"
            android:maxLines="4"
            android:ellipsize="end"
            android:textColor="#555555"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="end">

            <Button
                android:id="@+id/btnIgnore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ignora"
                android:backgroundTint="#757575"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnDeletePostAdmin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ELIMINA POST"
                android:backgroundTint="#D32F2F"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>